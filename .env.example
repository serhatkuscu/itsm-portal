# Copy this file to .env and fill in your values before running docker compose
# .env is gitignored — never commit real secrets

# PostgreSQL password (used by both postgres container and API connection string)
POSTGRES_PASSWORD=your_strong_password_here

# JWT signing key — must be at least 32 characters, cryptographically random
# Generate with: openssl rand -base64 48
JWT_SECRET_KEY=your_at_least_32_character_secret_key_here
